# FeatherCore .gitignore

# Build artifacts
## Build tool build output
build_tool/target/
boot/target/
kernel/target/
common/target/

# Top-level target directory (IDE/rust-analyzer cache)
target/

# Generated linker scripts (these are generated by build_tool)
boot/link.x
kernel/link.x

# Generated device tree
common/src/generated/

# Cargo lock files (optional - can be kept if reproducible builds are needed)
**/Cargo.lock

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build scripts output
*.o
*.a
*.bin
*.elf
*.hex

# Rust specific
**/*.rlib
**/*.d
**/.fingerprint/

# Log files
*.log
