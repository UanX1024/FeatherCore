// ESP32-C3-DevKitC Device Tree
// ESP32-C3-DevKitC 设备树
//
// 基于 Zephyr 的 esp32c3_devkitc 设备树配置移植

/dts-v1/;

/ {
    model = "Espressif ESP32C3-DevkitC";
    compatible = "espressif,esp32c3";

    // 内存定义
    // SRAM1
    sram1: memory@403ce000 {
        device_type = "memory";
        reg = <0x403ce000 0x20000>;
    };

    // Flash
    flash0: flash@0 {
        compatible = "soc-nv-flash";
        reg = <0x00000000 0x400000>;
    };

    // GPIO 按键节点定义
    gpio_keys {
        compatible = "gpio-keys";

        user_button1: button_1 {
            label = "User SW1";
            gpios = <&gpio0 9 9>;
            status = "okay";
        };
    };

    // SoC 节点定义
    soc {
        #address-cells = <1>;
        #size-cells = <1>;
        compatible = "espressif,esp32c3";
        ranges;

        // GPIO0 控制器
        gpio0: gpio@3ff44000 {
            compatible = "espressif,gpio";
            reg = <0x3ff44000 0x400>;
            status = "okay";
        };

        // UART0 串口节点定义
        uart0: serial@3ff40000 {
            compatible = "espressif,uart";
            reg = <0x3ff40000 0x400>;
            interrupts = <22>;
            status = "okay";
            current-speed = <115200>;
        };

        // USB Serial 控制器
        usb_serial: usb@60000000 {
            compatible = "espressif,usb-serial";
            reg = <0x60000000 0x10000>;
            interrupts = <20>;
            status = "okay";
        };

        // I2C0 总线节点定义
        i2c0: i2c@3ff3f000 {
            compatible = "espressif,i2c";
            reg = <0x3ff3f000 0x1000>;
            interrupts = <27>;
            clock-frequency = <100000>;
            status = "okay";
        };

        // SPI2 总线节点定义
        spi2: spi@3ff64000 {
            compatible = "espressif,spi";
            reg = <0x3ff64000 0x1000>;
            interrupts = <36>;
            status = "okay";
        };

        // I2S 音频接口
        i2s: i2s@3ff4f000 {
            compatible = "espressif,i2s";
            reg = <0x3ff4f000 0x1000>;
            interrupts = <35>;
            status = "okay";
        };

        // TRNG 随机数生成器
        trng0: trng@3ff5e000 {
            compatible = "espressif,trng";
            reg = <0x3ff5e000 0x1000>;
            status = "okay";
        };

        // 看门狗
        wdt0: watchdog@3ff5f000 {
            compatible = "espressif,wdt";
            reg = <0x3ff5f000 0x1000>;
            status = "okay";
        };

        // TWAI 控制器
        twai: can@3ff4b000 {
            compatible = "espressif,twai";
            reg = <0x3ff4b000 0x1000>;
            interrupts = <32>;
            status = "disabled";
        };

        // WiFi 控制器
        wifi: wifi@3ff00000 {
            compatible = "espressif,wifi";
            reg = <0x3ff00000 0x20000>;
            status = "okay";
        };

        // Bluetooth 控制器
        esp32_bt_hci: bt@3ff00000 {
            compatible = "espressif,bt-hci";
            reg = <0x3ff00000 0x20000>;
            status = "okay";
        };
    };

    aliases {
        sw0 = &user_button1;
        i2c-0 = &i2c0;
        watchdog0 = &wdt0;
        console = &uart0;
        serial0 = &uart0;
    };
};
