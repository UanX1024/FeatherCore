// STM32F429I-DISC Device Tree
// STM32F429I-DISC 设备树
//
// 设备树的核心是定义 "硬件属性"（寄存器地址、中断号、时钟、兼容标识等），不定义 "驱动逻辑"
// 驱动代码通过「通用逻辑 + 适配层」处理不同 SoC 的外设操作差异，适配层由设备树的 compatible 属性触发
//
// 基于 Zephyr 的 stm32f429i_disc1 设备树配置移植

/dts-v1/;

/ {
    // 开发板模型描述
    // 开发板的名称和兼容标识，用于驱动匹配
    model = "STMicroelectronics STM32F429I Discovery";
    compatible = "st,stm32f4discovery";

    // 内存定义
    // 内部 SRAM
    sram0: memory@20000000 {
        device_type = "memory";
        compatible = "mmio-sram";
        reg = <0x20000000 0x30000>;
    };

    // DTCM (Data Tightly Coupled Memory)
    ccm0: memory@20000000 {
        compatible = "zephyr,memory-region", "mmio-sram";
        reg = <0x20000000 0x10000>;
        zephyr,memory-region = "DTCM";
    };

    // 外部 SDRAM (8MB)
    sdram2: memory@d0000000 {
        compatible = "zephyr,memory-region", "mmio-sram";
        device_type = "memory";
        reg = <0xd0000000 DT_SIZE_M(8)>;
        zephyr,memory-region = "SDRAM2";
    };

    // LED 设备节点定义
    // 定义 LED 的引脚配置等硬件属性
    leds {
        compatible = "gpio-leds";

        // LD3 (绿色 LED)
        green_led_3: led_3 {
            // 兼容标识，用于匹配对应的 LED 驱动
            compatible = "gpio-leds";
            // GPIO 引脚编号: PG13
            gpios = <&gpiog 13 0>;
            // LED 标签
            label = "User LD3";
        };

        // LD4 (红色 LED)
        red_led_4: led_4 {
            // 兼容标识，用于匹配对应的 LED 驱动
            compatible = "gpio-leds";
            // GPIO 引脚编号: PG14
            gpios = <&gpiog 14 0>;
            // LED 标签
            label = "User LD4";
        };
    };

    // GPIO 按键节点定义
    gpio_keys {
        compatible = "gpio-keys";

        // 用户按钮
        user_button: button {
            label = "User";
            // GPIO 引脚编号: PA0
            gpios = <&gpioa 0 16>;
            zephyr,code = <0>;
        };
    };

    // SoC (System on Chip) 节点定义
    // 包含所有片上外设的硬件属性
    soc {
        #address-cells = <1>;
        #size-cells = <1>;
        // SoC 兼容标识
        compatible = "st,stm32f429";
        // 地址转换范围
        ranges;

        // GPIOA 控制器
        gpioa: gpio@40020000 {
            compatible = "st,stm32-gpio";
            reg = <0x40020000 0x400>;
            clocks = <&rcc 0>;
        };

        // GPIOG 控制器
        gpiog: gpio@40021000 {
            compatible = "st,stm32-gpio";
            reg = <0x40021000 0x400>;
            clocks = <&rcc 0>;
        };

        // UART1 串口节点定义
        // 定义串口的寄存器地址、中断号、时钟频率等硬件属性
        usart1: serial@40013800 {
            // 兼容标识，用于匹配对应的 UART 驱动
            compatible = "st,stm32-usart";
            // 寄存器基地址和大小
            // base address = 0x40013800, size = 0x400
            reg = <0x40013800 0x400>;
            // 中断号
            interrupts = <37>;
            // 时钟频率，单位 Hz
            clock-frequency = <180000000>;
            // 波特率
            current-speed = <115200>;
            // 状态
            status = "okay";
        };

        // I2C1 总线节点定义
        i2c1: i2c@40005400 {
            // 兼容标识，用于匹配对应的 I2C 驱动
            compatible = "st,stm32-i2c";
            // 寄存器基地址和大小
            reg = <0x40005400 0x400>;
            // 中断号
            interrupts = <31>;
            // 时钟频率，单位 Hz
            clock-frequency = <100000>;
            // 状态
            status = "okay";
        };

        // SPI5 总线节点定义
        spi5: spi@40015000 {
            // 兼容标识，用于匹配对应的 SPI 驱动
            compatible = "st,stm32-spi";
            // 寄存器基地址和大小
            reg = <0x40015000 0x400>;
            // 中断号
            interrupts = <44>;
            // 时钟频率，单位 Hz
            clock-frequency = <18000000>;
            // 状态
            status = "okay";
        };

        // FMC (Flexible Memory Controller) 控制器
        // 用于连接外部 SDRAM
        fmc: fmc@40021000 {
            compatible = "st,stm32-fmc";
            reg = <0x40021000 0x400>;
            clocks = <&rcc 0>;
            status = "okay";
        };

        // LTDC (LCD-TFT Display Controller) 控制器
        ltdc: ltdc@40016800 {
            compatible = "st,stm32-ltdc";
            reg = <0x40016800 0x400>;
            interrupts = <88>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        // USB OTG HS 控制器
        usbotg_hs: usb@40040000 {
            compatible = "st,stm32-otghs";
            reg = <0x40040000 0x40000>;
            interrupts = <71 74>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        // RCC (Reset and Clock Control) 控制器
        rcc: rcc@40023800 {
            compatible = "st,stm32-rcc";
            reg = <0x40023800 0x400>;
            clocks = <&pll>;
        };
    };

    // 别名定义
    // 为常用设备提供简短的别名，方便驱动查找
    aliases {
        led0 = &green_led_3;
        sw0 = &user_button;
        console = &usart1;
        serial0 = &usart1;
    };
};