// STM32N6570-DK Device Tree
// STM32N6570-DK 设备树
//
// 基于 Zephyr 的 stm32n6570_dk 设备树配置移植

/dts-v1/;

/ {
    model = "STMicroelectronics STM32N6570 Discovery Kit board";
    compatible = "st,stm32n6570-dk";

    // 内存定义
    axisram1: memory@38000000 {
        device_type = "memory";
        compatible = "mmio-sram";
        reg = <0x38000000 0x20000>;
    };

    axisram2: memory@38020000 {
        device_type = "memory";
        compatible = "mmio-sram";
        reg = <0x38020000 0x20000>;
    };

    psram: memory@90000000 {
        device_type = "memory";
        compatible = "zephyr,memory-region";
        reg = <0x90000000 DT_SIZE_M(32)>;
        zephyr,memory-region = "PSRAM";
    };

    ext_flash: flash@70000000 {
        compatible = "zephyr,memory-region";
        reg = <0x70000000 0x10000000>;
        zephyr,memory-region = "EXTFLASH";
    };

    // LED 设备节点定义
    leds {
        compatible = "gpio-leds";

        green_led_1: led_1 {
            compatible = "gpio-leds";
            gpios = <&gpioo 1 0>;
            label = "User LD1";
        };

        red_led_1: led_2 {
            compatible = "gpio-leds";
            gpios = <&gpiog 10 16>;
            label = "User LD2";
        };
    };

    // GPIO 按键节点定义
    gpio_keys {
        compatible = "gpio-keys";

        user_button: button {
            label = "User";
            gpios = <&gpioc 13 0>;
            zephyr,code = <0>;
        };
    };

    // SoC 节点定义
    soc {
        #address-cells = <1>;
        #size-cells = <1>;
        compatible = "st,stm32n6570";
        ranges;

        gpioa: gpio@50020000 {
            compatible = "st,stm32-gpio";
            reg = <0x50020000 0x400>;
            clocks = <&rcc 0>;
        };

        gpioc: gpio@50020400 {
            compatible = "st,stm32-gpio";
            reg = <0x50020400 0x400>;
            clocks = <&rcc 0>;
        };

        gpiog: gpio@50021000 {
            compatible = "st,stm32-gpio";
            reg = <0x50021000 0x400>;
            clocks = <&rcc 0>;
        };

        gpioo: gpio@50021800 {
            compatible = "st,stm32-gpio";
            reg = <0x50021800 0x400>;
            clocks = <&rcc 0>;
        };

        usart1: serial@4000e000 {
            compatible = "st,stm32-usart";
            reg = <0x4000e000 0x400>;
            interrupts = <36>;
            status = "okay";
        };

        i2c2: i2c@40015c00 {
            compatible = "st,stm32-i2c";
            reg = <0x40015c00 0x400>;
            interrupts = <50>;
            status = "okay";
        };

        fdcan1: fdcan@4000a000 {
            compatible = "st,stm32-fdcan";
            reg = <0x4000a000 0x3000>;
            interrupts = <19 20>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        usbotg_hs: usb@40000000 {
            compatible = "st,stm32-otghs";
            reg = <0x40000000 0x40000>;
            interrupts = <98 99>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        sdmmc1: sdmmc@480c4000 {
            compatible = "st,stm32-sdmmc";
            reg = <0x480c4000 0x1000>;
            interrupts = <49 50>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        ltdc: ltdc@5a010000 {
            compatible = "st,stm32-ltdc";
            reg = <0x5a010000 0x1000>;
            interrupts = <89>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        rcc: rcc@44000000 {
            compatible = "st,stm32n6-rcc";
            reg = <0x44000000 0x10000>;
            clocks = <&pll1>;
        };
    };

    aliases {
        led0 = &green_led_1;
        sw0 = &user_button;
        console = &usart1;
        serial0 = &usart1;
    };
};
