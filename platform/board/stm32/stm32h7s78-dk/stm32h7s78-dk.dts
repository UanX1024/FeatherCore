// STM32H7S78-DK Device Tree
// STM32H7S78-DK 设备树
//
// 设备树的核心是定义 "硬件属性"（寄存器地址、中断号、时钟、兼容标识等），不定义 "驱动逻辑"
// 驱动代码通过「通用逻辑 + 适配层」处理不同 SoC 的外设操作差异，适配层由设备树的 compatible 属性触发
//
// 基于 Zephyr 的 stm32h7s78_dk 设备树配置移植

/dts-v1/;

/ {
    // 开发板模型描述
    // 开发板的名称和兼容标识，用于驱动匹配
    model = "STMicroelectronics STM32H7S78 DISCOVERY KIT board";
    compatible = "st,stm32h7s78-dk";

    // 内存定义
    // 内部 SRAM
    sram0: memory@30000000 {
        device_type = "memory";
        compatible = "mmio-sram";
        reg = <0x30000000 0x70000>;
    };

    // DTCM (Data Tightly Coupled Memory)
    ccm0: memory@20000000 {
        compatible = "zephyr,memory-region", "mmio-sram";
        reg = <0x20000000 0x20000>;
        zephyr,memory-region = "DTCM";
    };

    // 外部 Flash (OctoSPI)
    ext_flash: flash@60000000 {
        compatible = "zephyr,memory-region", "mmio-sram";
        reg = <0x60000000 0x8000000>;
        zephyr,memory-region = "EXTFLASH";
    };

    // LED 设备节点定义
    leds {
        compatible = "gpio-leds";

        // LD1
        led1: led_1 {
            compatible = "gpio-leds";
            // GPIO 引脚编号: PD13
            gpios = <&gpiod 13 0>;
            label = "LD1";
        };
    };

    // GPIO 按键节点定义
    gpio_keys {
        compatible = "gpio-keys";

        // 用户按钮
        user_button: button {
            label = "User";
            // GPIO 引脚编号: PC13
            gpios = <&gpioc 13 16>;
            zephyr,code = <0>;
        };
    };

    // SoC (System on Chip) 节点定义
    soc {
        #address-cells = <1>;
        #size-cells = <1>;
        // SoC 兼容标识
        compatible = "st,stm32h7s7";
        // 地址转换范围
        ranges;

        // GPIOA 控制器
        gpioa: gpio@48000000 {
            compatible = "st,stm32-gpio";
            reg = <0x48000000 0x400>;
            clocks = <&rcc 0>;
        };

        // GPIOC 控制器
        gpioc: gpio@48000400 {
            compatible = "st,stm32-gpio";
            reg = <0x48000400 0x400>;
            clocks = <&rcc 0>;
        };

        // GPIOD 控制器
        gpiod: gpio@48000800 {
            compatible = "st,stm32-gpio";
            reg = <0x48000800 0x400>;
            clocks = <&rcc 0>;
        };

        // GPIOG 控制器
        gpiog: gpio@48001400 {
            compatible = "st,stm32-gpio";
            reg = <0x48001400 0x400>;
            clocks = <&rcc 0>;
        };

        // LPUART1 串口节点定义
        lpuart1: serial@48101800 {
            // 兼容标识，用于匹配对应的 UART 驱动
            compatible = "st,stm32-lpuart";
            // 寄存器基地址和大小
            reg = <0x48101800 0x400>;
            // 中断号
            interrupts = <20>;
            // 状态
            status = "okay";
        };

        // I2C4 总线节点定义
        i2c4: i2c@48001400 {
            // 兼容标识，用于匹配对应的 I2C 驱动
            compatible = "st,stm32-i2c";
            // 寄存器基地址和大小
            reg = <0x48001400 0x400>;
            // 中断号
            interrupts = <101>;
            // 时钟频率，单位 Hz
            clock-frequency = <100000>;
            // 状态
            status = "okay";
        };

        // OctoSPI1 控制器
        octospi1: octospi@52004000 {
            compatible = "st,stm32-octospi";
            reg = <0x52004000 0x400>;
            interrupts = <137>;
            clocks = <&rcc 0>;
            status = "okay";
        };

        // USB OTG FS 控制器
        usbotg_fs: usb@48080000 {
            compatible = "st,stm32-otgfs";
            reg = <0x48080000 0x40000>;
            interrupts = <67>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        // ADC1 控制器
        adc1: adc@48004000 {
            compatible = "st,stm32-adc";
            reg = <0x48004000 0x400>;
            interrupts = <18>;
            clocks = <&rcc 0>;
            status = "disabled";
        };

        // RCC (Reset and Clock Control) 控制器
        rcc: rcc@58000400 {
            compatible = "st,stm32h7-rcc";
            reg = <0x58000400 0x400>;
            clocks = <&pll>;
        };
    };

    // 别名定义
    // 为常用设备提供简短的别名，方便驱动查找
    aliases {
        led0 = &led1;
        sw0 = &user_button;
        console = &lpuart1;
        serial0 = &lpuart1;
    };
};
